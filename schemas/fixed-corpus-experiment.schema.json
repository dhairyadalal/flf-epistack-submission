{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/epistemic-audit/fixed-corpus-experiment.schema.json",
  "title": "Fixed-corpus source-policy experiment",
  "type": "object",
  "required": [
    "schema_version",
    "experiment_id",
    "case_id",
    "baseline_id",
    "question",
    "policies",
    "assessment_method",
    "evidence_clusters",
    "coverage_report"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "experiment_id": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "baseline_id": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "policies": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["policy_id", "label", "description", "selection"],
        "properties": {
          "policy_id": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "selection": {
            "type": "object",
            "required": ["include_all", "evidence_types", "evidence_ids"],
            "properties": {
              "include_all": { "type": "boolean" },
              "evidence_types": { "type": "array", "items": { "type": "string" } },
              "evidence_ids": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "assessment_method": {
      "type": "object",
      "required": ["unit", "strength_scale", "aggregation", "interpretation"],
      "properties": {
        "unit": { "type": "string" },
        "strength_scale": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "aggregation": { "type": "string" },
        "interpretation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence_clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cluster_id", "label", "description", "evidence_ids"],
        "properties": {
          "cluster_id": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "coverage_report": {
      "type": "object",
      "required": ["known_but_unavailable", "capability_limited", "not_established"],
      "properties": {
        "known_but_unavailable": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverageItem" }
        },
        "capability_limited": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverageItem" }
        },
        "not_established": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverageItem" }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "coverageItem": {
      "type": "object",
      "required": ["label", "note", "evidence_ids"],
      "properties": {
        "label": { "type": "string" },
        "note": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
